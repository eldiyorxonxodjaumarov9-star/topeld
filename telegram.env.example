# Bitta bot — contact, visit, chatbot hammasi shu token/guruh bilan ishlaydi.
# Asosiy usul: src/config/telegram.ts

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_group_chat_id

# Production sayt URL (webhook avtomatik ulanadi)
NEXT_PUBLIC_SITE_URL=https://topeldsolutions.com

# Upstash Redis — Telegram reply larni website chatga yetkazish uchun MAJBURIY (production)
# https://console.upstash.com → Create Database → REST API → Copy
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
